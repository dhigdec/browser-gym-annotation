# Copy to .env and adjust. Never commit .env.

# ---- Backend (native dev) ----
DATABASE_URL=postgresql+psycopg://localhost:5432/browser_gym_annotator
CORS_ORIGINS=["http://localhost:5180"]
ENV=dev
# Path to the gym repo (imported for verifiers/oracle in later milestones)
GYM_REPO_PATH=

# ---- docker-compose Postgres ----
POSTGRES_USER=annotator
POSTGRES_PASSWORD=annotator
POSTGRES_DB=browser_gym_annotator
